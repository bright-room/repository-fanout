{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>bright-room/renovate-config",
    "github>bright-room/renovate-config:typescript",
    "config:recommended"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": [
    "before 9am on saturday"
  ],
  "labels": [
    "Kind: Dependencies"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "separateMinorPatch": true,
  "terraform": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 9am on saturday"
    ]
  },
  "minimumReleaseAge": "7 days",
  "automerge": true,
  "major": {
    "minimumReleaseAge": "14 days",
    "automerge": false
  }
}

{
  "_comment": "renovate の extends エントリ・gitignore 行・配布ファイル(files/) を1つの language に集約した例。",
  "renovate": ["github>bright-room/renovate-config:typescript"],
  "gitignore": [
    { "section_comment": "node", "ignores": ["node_modules/", "dist/", "*.tsbuildinfo", "npm-debug.log*", "pnpm-debug.log*"] }
  ]
}
